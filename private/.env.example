# Image built from tokenhub-proxy source (see install.sh / docker compose --build).
# LITELLM_IMAGE is the full image reference. Add your own registry/prefix here
# when you want to push it somewhere, e.g. registry.example.internal/litellm-database:local
LITELLM_IMAGE=litellm-database:local
LITELLM_CONFIG_PATH=./config.example.yaml
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-replace-with-a-random-admin-key
LITELLM_SALT_KEY=sk-replace-with-a-random-salt-key
# This fork builds from source and modifies the enterprise gate, so LITELLM_LICENSE
# does not control feature unlocking at runtime. Left here only for parity.
LITELLM_LICENSE=
LITELLM_NUM_WORKERS=1
RUN_MIGRATIONS=true
SKIP_BUILD=false
DATABASE_URL=postgresql://litellm:replace-me@postgres.example.internal:5432/litellm
DATABASE_URL_READ_REPLICA=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
OPENAI_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
SLACK_WEBHOOK_URL=
